# Integration Test Configuration
# Copy this file to .env and fill in the values.
# .env is loaded automatically by `just` (via dotenv-load).

# Enable all integration tests. Set to any non-empty value.
# Alternatively, use targeted variables below (e.g. INT_TEST_VCS=1).
# INT_TEST=1

# GitHub personal access token for VCS integration tests.
# Required by: pkg/vcs/github, pkg/vcs/repo
# Scopes needed: repo (for PR management tests)
GITHUB_TOKEN=

# Path to an SSH private key for git-over-SSH tests (optional).
# Used by: pkg/vcs/repo (clone/push over SSH)
GITHUB_KEY=
